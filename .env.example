APP_NAME="Potty Direct"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://pottydirect.test
APP_KEY=base64:xFdNDocRrXpx3h3T0GaQZ8/UBni8B9MGW7zQFCEIWaM=

# Domain for local development (pottydirect, waterdamage)
APP_DOMAIN=pottydirect

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=porta_potty
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=redis
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_CONNECTION=session
QUEUE_CONNECTION=redis

# For local dev without Redis running, override the above in .env (NOT .env.example):
#   CACHE_STORE=file
#   CACHE_DRIVER=file
#   SESSION_DRIVER=file
#   QUEUE_CONNECTION=sync
# Or: brew services start redis

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# SignalWire
SIGNALWIRE_PROJECT_ID=your-project-id
SIGNALWIRE_API_TOKEN=your-api-token
SIGNALWIRE_SPACE_URL=yourspace.signalwire.com

# Call Settings
CALL_MIN_DURATION=90
CALL_DUPLICATE_HOURS=72

# Business Settings
DEFAULT_BUYER_PHONE=+1XXXXXXXXXX
BUSINESS_HOURS_START=07:00
BUSINESS_HOURS_END=20:00
BUSINESS_TIMEZONE=America/Chicago

# Contact Information
CONTACT_PHONE_RAW=+18336529344
CONTACT_PHONE_DISPLAY="(833) 652-9344"

# Business hours — drive the LocalBusiness schema + the time-of-day-aware
# announcement banner ("We open at 7 AM" outside of hours).
# Format: HH:MM in 24-hour time. Set OPEN=00:00 and CLOSE=23:59 for true 24/7.
CONTACT_HOURS_OPEN=07:00
CONTACT_HOURS_CLOSE=20:00
CONTACT_HOURS_LABEL="Mon–Sun, 7 AM – 8 PM CT"

# Aggregate review rating (schema markup). Leave REVIEWS_COUNT unset until
# you have a defensible audited count (e.g., from Google Business Profile).
# When unset, no AggregateRating schema is emitted — that's the safe default.
REVIEWS_RATING=4.9
# REVIEWS_COUNT=15

IP_GEOLOCATION_ENABLED=false
DAILY_CITY_PAGE_GENERATION=2

# Blog auto-publish: AI-generated posts are now published immediately by default.

# Service pricing schema — off by default until you have verified market prices.
# When off: no AggregateOffer in schema, no "From $X/day" in meta descriptions.
# When you turn this on, make sure the ranges in config/service_pricing.php
# match what your dispatcher will actually quote on the phone.
SERVICE_PRICING_SCHEMA=false

# Geo-redirect: homepage visitors auto-routed to their nearest city page.
# Default off — enable only if you understand the CTR/conversion tradeoff.
# Uses Cloudflare headers (CF-IPCountry, CF-IPCity) when available.
GEO_REDIRECT_ENABLED=false
# Fallback to ipapi.co if Cloudflare headers absent. Off by default
# (blocks LCP on external HTTP call; also rate-limited at 1k/day on free tier).
FEATURE_IPAPI_FALLBACK=false

# Google Indexing API (for SEO - submit new pages to Google)
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
GOOGLE_SEARCH_CONSOLE_URL=https://yourdomain.com

# Google Analytics 4
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
